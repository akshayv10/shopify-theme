    "custom_liquid_LKxPyY": {
      "type": "custom-liquid",
      "name": "t:sections.custom-liquid.presets.name",
      "settings": {
        "custom_liquid": "<style>\n#scroll-video {\n  width: 100%; /* Default: full width for mobile */\n  height: auto;\n  display: block;\n  margin: 0 auto;\n  overflow: hidden; /* Prevent overflow for future styling */\n  box-shadow: 0px 8px 16px rgba(0, 0, 0, 0.1); /* Shadow for both mobile and desktop */\n\n}\n\n@media (min-width: 768px) {\n  #scroll-video {\n    width: 50%; /* Adjust for desktop (60% of container width) */\n    border: 2px solid black; /* Thin black border for desktop */\n    border-radius: 12px; /* Rounded corners only for desktop */\n    box-shadow: 0px 8px 16px rgba(0, 0, 0, 0.3); /* Stronger shadow for desktop */\n  }\n}\n</style>\n\n<video id=\"scroll-video\" muted playsinline autoplay loop>\n  <source src=\"https://cdn.shopify.com/videos/c/o/v/e4df7787cc6b41cca56c150a5078d389.mp4\">\n  Your browser does not support the video tag.\n</video>\n\n<script>\ndocument.addEventListener('DOMContentLoaded', function() {\n  const video = document.querySelector('#scroll-video');\n\n  // Ensure the video is muted programmatically\n  video.muted = true;\n\n  // Play the video automatically when it comes into view\n  const playVideo = (entries, observer) => {\n    entries.forEach(entry => {\n      if (entry.isIntersecting) {\n        video.play();\n        observer.disconnect(); // Stop observing once video starts playing\n      }\n    });\n  };\n\n  const observer = new IntersectionObserver(playVideo, {\n    threshold: 0.5, // Trigger when 50% of the video is visible\n  });\n\n  observer.observe(video);\n});\n</script>",
        "color_scheme": "",
