econdary_image":true,"show_vendor":false,"show_rating":false,"padding_top":0,"padding_bottom":60}},"custom_liquid_3ekCpg":{"type":"custom-liquid","settings":{"custom_liquid":"<style>\n\/* Wrapper to center video *\/\n.video-container {\n  width: 100%; \/* Full width for mobile *\/\n  max-width: 100%;\n  display: flex;\n  justify-content: center; \/* Ensures centering *\/\n  align-items: center;\n  overflow: hidden; \/* Prevents extra space *\/\n  background-color: black; \/* Avoids any white gaps *\/\n}\n\n@media (min-width: 768px) {\n  .video-container {\n    width: 70%; \/* Restrict width on desktop *\/\n    margin: 0 auto; \/* Centers the container *\/\n    border: 2px solid black; \/* Border wraps around video *\/\n    border-radius: 12px; \/* Rounded corners *\/\n    box-shadow: 0px 8px 16px rgba(0, 0, 0, 0.2); \/* Equal shadow *\/\n  }\n}\n\n#scroll-video {\n  width: 100%;\n  height: auto;\n  display: block;\n  margin: 0 auto;\n  padding: 0;\n  border: none; \/* Remove extra border *\/\n  object-fit: cover; \/* Ensures video fills container *\/\n}\n<\/style>\n\n<!-- Wrap the video inside a properly centered container -->\n<div class=\"video-container\">\n  <video id=\"scroll-video\" muted playsinline autoplay loop>\n    <source src=\"https:\/\/cdn.shopify.com\/videos\/c\/o\/v\/39e887ebbec44f31b5c30453b33ab876.mp4\" type=\"video\/mp4\">\n    Your browser does not support the video tag.\n  <\/video>\n<\/div>\n\n<script>\ndocument.addEventListener('DOMContentLoaded', function() {\n  const video = document.querySelector('#scroll-video');\n\n  \/\/ Ensure the video is muted programmatically\n  video.muted = true;\n\n  \/\/ Play the video automatically when it comes into view\n  const playVideo = (entries, observer) => {\n    entries.forEach(entry => {\n      if (entry.isIntersecting) {\n        video.play();\n        observer.disconnect(); \/\/ Stop observing once video starts playing\n      }\n    });\n  };\n\n  const observer = new IntersectionObserver(playVideo, {\n    threshold: 0.5, \/\/ Trigger when 50% of the video is visible\n  });\n\n  observer.observe(video);\n});\n<\/script>","color_scheme":"scheme-1","padding_top":8,"padding_bottom":40}}},"order":["rich_text_UDrL3y","main","collapsible_content_RCUnGg","rich_text_wPUPqK","video_dcjKHR","related-products","custom_liquid_3ekCpg"]}